# ============================================================================
# Starlink Subscription API - Configuración de Entorno
# ============================================================================

# ----------------------------------------------------------------------------
# Configuración General
# ----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
ORGANIZATION_ID=default
TIMEZONE=America/Caracas
DEFAULT_ADMIN_ID=local-admin

# ----------------------------------------------------------------------------
# Firebase - AUTENTICACIÓN
# ----------------------------------------------------------------------------
# Hay DOS métodos para autenticarse con Firebase. Elije UNO solo:
#
# OPCIÓN 1: Variables de entorno (RECOMENDADO para Railway/producción)
#   Ventaja: No requiere archivos físicos, compatible con PaaS
#   Configura estas dos variables:
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
#
# OPCIÓN 2: Archivo JSON local (para desarrollo local)
#   Ventaja: Más simple para desarrollo
#   Desventaja: Requiere proteger el archivo de subirse al repo
#   Configura esta variable con la ruta al archivo:
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./credentials/firebase-admin.json
#
# IMPORTANTE: La OPCIÓN 1 tiene prioridad sobre la OPCIÓN 2 si ambas están configuradas.
#
# ID del proyecto de Firebase
FIREBASE_PROJECT_ID=api-gestion-starlink

# ----------------------------------------------------------------------------
# Twilio - SMS/WhatsApp
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=
TWILIO_WHATSAPP_REMINDER_SID=
TWILIO_WHATSAPP_CUTOFF_SID=
TWILIO_WHATSAPP_SUSPENDED_SID=
TWILIO_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# JWT - Autenticación
# ----------------------------------------------------------------------------
# Secreto para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=
# Expiración de tokens: 1h, 12h, 24h, 7d
JWT_EXPIRES_IN=24h
